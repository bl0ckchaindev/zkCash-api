# Solana RPC endpoint (devnet, mainnet-beta, or custom)
# For devnet testing: https://api.devnet.solana.com
RPC_URL=https://api.devnet.solana.com

# Optional WebSocket URL (same cluster as RPC_URL). The indexer uses WSS for log subscriptions; if you see
# "ws error: getaddrinfo ENOTFOUND ..." intermittently, DNS to that host is failing — try reliable DNS,
# NODE_OPTIONS=--dns-result-order=ipv4first, or point WSS at another provider, e.g.:
# RPC_WS_URL=wss://api.mainnet-beta.solana.com
# RPC_WS_URL=

# Indexer: HTTP reconcile of recent signatures (default 10000 ms). Overlaps WebSocket logs so missed WS events are repaired.
# Set to 0 to disable (not recommended in production).
# INDEXER_HTTP_POLL_MS=10000
# Max signatures scanned per reconcile tick (default 1000). Raise if the program can outpace this between polls.
# INDEXER_RECONCILE_SIGNATURE_CAP=1000

# Network - set to 'devnet' when RPC is devnet (or inferred from RPC_URL)
NETWORK=devnet

# ZKCash program ID (from Anchor.toml)
PROGRAM_ID=9B3yaayBtBaJspPQ3ggkN31By3a3qjRZtJEmCgtogqAt

# Relayer keypair path (for signing deposit/withdraw relay transactions)
# Generate with: solana-keygen new -o relayer-keypair.json
RELAYER_KEYPAIR_PATH=./relayer-keypair.json

# Address Lookup Table for compact transactions
ALT_ADDRESS=HEN49U2ySJ85Vc78qprSW9y6mFDhs1NczRxyppNHjofe

# Fee recipient (receives withdrawal fees)
FEE_RECIPIENT=AWexibGxNFKTa1b5R5MN4PJr9HWnWRwf8EW9g8cLx3dM

# Server port
PORT=3001

# MongoDB (commitments index) — include database in the URI path (e.g. .../zkcash)
MONGODB_URI=mongodb://localhost:27017/zkcash

# CORS - comma-separated origins, or * for all (avoid * in production)
CORS_ORIGINS=https://your-frontend.com,https://app.your-frontend.com

# Cache TTL (ms) - config and merkle root
CONFIG_CACHE_TTL_MS=30000
MERKLE_CACHE_TTL_MS=10000
